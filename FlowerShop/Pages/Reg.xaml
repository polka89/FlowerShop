<Page x:Class="FlowerShop.Pages.Reg"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Reg">
    <ScrollViewer>
        <Grid Margin="20">
            <GroupBox Header="Регистрация флориста / менеджера" Width="460" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Создайте аккаунт в Flower Shop 🌺" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>

                    <TextBlock Text="Имя пользователя"/>
                    <TextBox x:Name="TbUserName" Margin="0,4,0,10" TextChanged="Input_TextChanged"/>

                    <TextBlock Text="Дата рождения"/>
                    <DatePicker x:Name="DpBirthDate" Margin="0,4,0,10" SelectedDateChanged="Input_TextChanged"/>

                    <TextBlock Text="Стаж / опыт"/>
                    <TextBox x:Name="TbExperience" Margin="0,4,0,10" TextChanged="Input_TextChanged"/>

                    <TextBlock Text="Логин"/>
                    <TextBox x:Name="TbLogin" Margin="0,4,0,10" TextChanged="Input_TextChanged"/>

                    <TextBlock Text="Пароль"/>
                    <PasswordBox x:Name="PbPassword" Margin="0,4,0,10" PasswordChanged="PasswordBoxes_PasswordChanged"/>

                    <TextBlock Text="Подтверждение пароля"/>
                    <PasswordBox x:Name="PbPasswordConfirm" Margin="0,4,0,10" PasswordChanged="PasswordBoxes_PasswordChanged"/>

                    <TextBlock Text="Почта"/>
                    <TextBox x:Name="TbEmail" Margin="0,4,0,10" TextChanged="Input_TextChanged"/>

                    <TextBlock Text="Телефон"/>
                    <TextBox x:Name="TbPhone" Margin="0,4,0,16" TextChanged="Input_TextChanged"/>

                    <TextBlock x:Name="TbValidation" Foreground="Red" Margin="0,0,0,10"/>

                    <Button x:Name="BtnRegister" Content="Зарегистрироваться" Height="34" IsEnabled="False" Click="BtnRegister_Click"/>
                    <Button Content="Назад к авторизации" Height="34" Margin="0,10,0,0" Click="BtnBack_Click"/>
                </StackPanel>
            </GroupBox>
        </Grid>
    </ScrollViewer>
</Page>
