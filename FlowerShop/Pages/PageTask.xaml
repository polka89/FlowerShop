<Page x:Class="FlowerShop.Pages.PageTask"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:FlowerShop.Pages"
      Title="Каталог FLOWWOW"
      Loaded="Page_Loaded">

    <Page.Resources>
        <!-- Конвертеры -->
        <local:ImagePathConverter x:Key="ImagePathConverter"/>
        <local:AvailabilityTextConverter x:Key="AvailabilityTextConverter"/>
        <local:AvailabilityColorConverter x:Key="AvailabilityColorConverter"/>
        <local:ImageConverter x:Key="ImageConverter"/>
        <local:StockColorConverter x:Key="StockColorConverter"/>

        <!-- Конвертер Bool в Visibility -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- Цвета из задания -->
        <SolidColorBrush x:Key="SoftPink" Color="#F896A3"/>
        <SolidColorBrush x:Key="PastelGreen" Color="#9C9E4A"/>
        <SolidColorBrush x:Key="MainBlack" Color="#242021"/>
        <SolidColorBrush x:Key="LightBrown" Color="#CCBE83"/>

        <!-- Стиль для кнопок категорий -->
        <Style x:Key="CategoryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource MainBlack}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PastelGreen}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Margin" Value="0,5,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Book Antiqua"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PastelGreen}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для кнопок действий -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PastelGreen}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Width" Value="110"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="FontFamily" Value="Book Antiqua"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="25"
                                Padding="10,5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource SoftPink}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для кнопки Назад -->
        <Style x:Key="BackButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource MainBlack}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PastelGreen}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="FontFamily" Value="Book Antiqua"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="25"
                                Padding="10,5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PastelGreen}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для кнопок корзины и истории -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource MainBlack}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PastelGreen}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Width" Value="45"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="22.5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PastelGreen}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для карточек товаров -->
        <Style x:Key="ProductCardStyle" TargetType="Border">
            <Setter Property="Width" Value="280"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для элементов корзины -->
        <Style x:Key="CartItemStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="5" ShadowDepth="1" Opacity="0.05" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для кнопки добавления в корзину -->
        <Style x:Key="AddToCartButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PastelGreen}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource SoftPink}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ЛЕВАЯ ПАНЕЛЬ - Категории -->
        <Border Grid.Column="0" Background="White" CornerRadius="0,20,20,0" 
                BorderBrush="#EEEEEE" BorderThickness="0,0,1,0">
            <StackPanel Margin="15">
                <TextBlock Text="🌸 FLOWWOW" FontSize="24" FontWeight="Bold" 
                           Foreground="{StaticResource MainBlack}" 
                           FontFamily="Book Antiqua"
                           Margin="0,0,0,25"
                           TextAlignment="Center"/>

                <TextBlock Text="Выбрать категорию" FontSize="16" FontWeight="SemiBold" 
                           Foreground="{StaticResource MainBlack}" 
                           FontFamily="Book Antiqua"
                           Margin="0,0,0,15"/>

                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="500">
                    <StackPanel>
                        <Button x:Name="BtnAllCategories" Content="🌿 Все" 
                                Style="{StaticResource CategoryButtonStyle}"
                                Click="BtnAllCategories_Click"/>
                        <ItemsControl x:Name="CategoriesPanel">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding Name}" 
                                            Tag="{Binding Id}"
                                            Style="{StaticResource CategoryButtonStyle}"
                                            Click="CategoryButton_Click"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!-- ПРАВАЯ ПАНЕЛЬ - Основной контент -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" 
                      HorizontalScrollBarVisibility="Disabled" 
                      Background="#FFF7EAEA"
                      CanContentScroll="True">

            <Grid Margin="20" x:Name="MainGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Шапка с иконками -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" 
                            HorizontalAlignment="Right" Margin="0,0,0,20">
                    <Button x:Name="BtnCart" Content="🛒" Style="{StaticResource IconButtonStyle}" 
                            Click="BtnCart_Click" ToolTip="Корзина"/>
                    <Button x:Name="BtnHistory" Content="📋" Style="{StaticResource IconButtonStyle}" 
                            Click="BtnHistory_Click" Margin="10,0,0,0" ToolTip="История заказов"/>
                    <Button x:Name="BtnLogout" Content="🚪" Style="{StaticResource IconButtonStyle}" 
                            Click="BtnLogout_Click" Margin="10,0,0,0" ToolTip="Выход"/>
                </StackPanel>

                <!-- Каталог товаров -->
                <Border Grid.Row="1" x:Name="CatalogView" Margin="0,0,0,20" Visibility="Visible">
                    <ListView x:Name="ProductsListView" 
                              SelectionMode="Single"
                              Background="Transparent"
                              BorderThickness="0"
                              HorizontalContentAlignment="Center"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Disabled">
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel HorizontalAlignment="Center"/>
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ProductCardStyle}">
                                    <StackPanel>
                                        <Border Height="220" Background="#F8F8F8" CornerRadius="16,16,0,0">
                                            <Image Source="{Binding ImageUrl, Converter={StaticResource ImageConverter}}" 
                                                   Stretch="Uniform" 
                                                   Width="200" Height="200"
                                                   Margin="10"/>
                                        </Border>

                                        <StackPanel Margin="15,12,15,15">
                                            <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" 
                                                       Foreground="{StaticResource MainBlack}" TextWrapping="Wrap"
                                                       MaxHeight="45" Margin="0,0,0,6" FontFamily="Book Antiqua"/>

                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <TextBlock Text="★" Foreground="#FFB800" FontSize="13"/>
                                                <TextBlock Text="{Binding RatingText}" Foreground="#888" FontSize="12" Margin="4,0,0,0"/>
                                            </StackPanel>

                                            <TextBlock Text="{Binding Price, StringFormat={}{0:N0} ₽}" FontSize="20" FontWeight="Bold" 
                                                       Foreground="{StaticResource PastelGreen}" Margin="0,0,0,4"/>

                                            <TextBlock Text="{Binding InstallmentText}" Foreground="{StaticResource LightBrown}" FontSize="10" Margin="0,0,0,8"/>

                                            <!-- Количество на складе -->
                                            <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                                                <TextBlock Text="📦 На складе:" FontSize="11" Foreground="#666"/>
                                                <TextBlock Text="{Binding Stock}" FontSize="11" FontWeight="Bold" Foreground="#4CAF50" Margin="5,0,0,0"/>
                                                <TextBlock Text=" шт." FontSize="11" Foreground="#666"/>
                                            </StackPanel>

                                            <!-- Выбор количества -->
                                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Center">
                                                <Button Content="-" Width="30" Height="30" Background="#EEEEEE" Foreground="Black"
                                                        Click="DecreaseQuantity_Click" Tag="{Binding}" FontSize="16" FontWeight="Bold"/>
                                                <TextBlock x:Name="QuantityText" Text="1" FontSize="14" FontWeight="Bold" 
                                                           Width="40" TextAlignment="Center" VerticalAlignment="Center"/>
                                                <Button Content="+" Width="30" Height="30" Background="#EEEEEE" Foreground="Black"
                                                        Click="IncreaseQuantity_Click" Tag="{Binding}" FontSize="16" FontWeight="Bold"/>
                                            </StackPanel>

                                            <Button Content="🛒 В корзину" Style="{StaticResource AddToCartButtonStyle}" Margin="0,10,0,0" 
                                                    Click="AddToCartWithQuantity_Click" Tag="{Binding}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>

                <!-- Корзина -->
                <Border Grid.Row="1" x:Name="CartView" Visibility="Collapsed" Margin="0,0,0,20">
                    <Border Background="White" CornerRadius="20" Padding="20">
                        <StackPanel>
                            <TextBlock Text="🛒 Корзина" FontSize="28" FontWeight="Bold" Foreground="{StaticResource MainBlack}" FontFamily="Book Antiqua" Margin="0,0,0,20"/>

                            <ListBox x:Name="CartListBox" Background="Transparent" BorderThickness="0" MaxHeight="400">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource CartItemStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Image Source="{Binding Product.ImageUrl, Converter={StaticResource ImageConverter}}" 
                                                       Width="60" Height="60" Stretch="Uniform"/>
                                                <StackPanel Grid.Column="1" Margin="10,0">
                                                    <TextBlock Text="{Binding Product.Name}" FontSize="14" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Product.Price, StringFormat={}{0:N0} ₽}" FontSize="12" Foreground="{StaticResource PastelGreen}"/>
                                                    <TextBlock Text="Количество: {Binding Quantity}" FontSize="11" Foreground="#666"/>
                                                </StackPanel>
                                                <Button Grid.Column="2" Content="🗑" Background="Transparent" Foreground="{StaticResource SoftPink}" BorderThickness="0" FontSize="18" Cursor="Hand" Click="RemoveFromCart_Click" Tag="{Binding}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <Border Height="1" Background="#EEEEEE" Margin="0,15,0,15"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="Итого: " FontSize="18" FontWeight="SemiBold"/>
                                <TextBlock x:Name="CartTotalText" Text="0 ₽" FontSize="22" FontWeight="Bold" Foreground="{StaticResource PastelGreen}"/>
                            </StackPanel>

                            <Button x:Name="BtnCheckout" Content="Оформить заказ ✅" Style="{StaticResource ActionButtonStyle}" Width="200" Margin="0,15,0,0" Click="BtnCheckout_Click"/>
                            <Button x:Name="BtnBackToCatalog" Content="← Вернуться в каталог" Style="{StaticResource BackButtonStyle}" Width="180" Margin="0,10,0,0" Click="BtnBackToCatalog_Click"/>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- История заказов -->
                <Border Grid.Row="1" x:Name="HistoryView" Visibility="Collapsed" Margin="0,0,0,20">
                    <Border Background="White" CornerRadius="20" Padding="20">
                        <StackPanel>
                            <TextBlock Text="📋 История заказов" FontSize="28" FontWeight="Bold" Foreground="{StaticResource MainBlack}" FontFamily="Book Antiqua" Margin="0,0,0,20"/>

                            <ListBox x:Name="HistoryListBox" Background="Transparent" BorderThickness="0" MaxHeight="400">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource CartItemStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="🛍️" FontSize="24" Margin="0,0,15,0"/>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding OrderDate}" FontSize="12" Foreground="{StaticResource LightBrown}"/>
                                                    <TextBlock Text="{Binding ItemsCount}" FontSize="14" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:N0} ₽}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource PastelGreen}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <Button x:Name="BtnBackFromHistory" Content="← Вернуться в каталог" Style="{StaticResource BackButtonStyle}" Width="180" Margin="0,15,0,0" Click="BtnBackFromHistory_Click"/>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- Кнопки действий администратора -->
                <Border Grid.Row="2" Background="White" CornerRadius="20" Padding="12" Margin="0,20,0,0" BorderBrush="#EEEEEE" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="BtnAdd" Content="➕ Добавить" Style="{StaticResource ActionButtonStyle}" Click="BtnAdd_Click"/>
                        <Button x:Name="BtnEdit" Content="✏️ Редактировать" Style="{StaticResource ActionButtonStyle}" Click="BtnEdit_Click"/>
                        <Button x:Name="BtnDelete" Content="🗑 Удалить" Style="{StaticResource ActionButtonStyle}" Click="BtnDelete_Click"/>
                        <Button x:Name="BtnBack" Content="⬅ Назад" Style="{StaticResource BackButtonStyle}" Click="BtnBack_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>