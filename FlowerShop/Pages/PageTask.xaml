<Page x:Class="FlowerShop.Pages.PageTask"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:FlowerShop.Pages"
      Title="Каталог FLOWWOW">

    <Page.Resources>
        <!-- Конвертеры как статические ресурсы -->
        <local:AvailabilityTextConverter x:Key="AvailabilityTextConverter"/>
        <local:AvailabilityColorConverter x:Key="AvailabilityColorConverter"/>
        <local:ImageConverter x:Key="ImageConverter"/>

        <!-- Стиль для карточек товаров -->
        <Style x:Key="ProductCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <!-- Стиль для выделения выбранной карточки -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="BorderBrush" Value="#7A3E65"/>
                    <Setter Property="BorderThickness" Value="2"/>
                    <Setter Property="Background" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#FFF9F9F9">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Шапка -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="FLOWWOW" FontSize="32" FontWeight="Bold" 
                           Foreground="#7A3E65" FontFamily="Segoe UI"/>
                <TextBlock Text="Каталог цветов" FontSize="16" 
                           Foreground="#5F2C4C" Margin="0,5,0,0" Opacity="0.7"/>
            </StackPanel>

            <!-- Фильтр по категориям -->
            <Border Grid.Row="1" Background="White" CornerRadius="12" 
                    Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Выбрать категорию" FontSize="16" FontWeight="SemiBold" 
                               Foreground="#5F2C4C" Margin="0,0,0,15"/>

                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <WrapPanel>
                            <Button x:Name="BtnAllCategories" Content="🌿 Все" 
                                    Width="80" Margin="5" Padding="8,5"
                                    Background="Transparent" BorderBrush="#7A3E65" BorderThickness="1"
                                    Foreground="#5F2C4C" Click="BtnAllCategories_Click"/>
                            <ItemsControl x:Name="CategoriesPanel">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding Name}" 
                                                Tag="{Binding Id}"
                                                Width="100" Margin="5" Padding="8,5"
                                                Background="Transparent" BorderBrush="#7A3E65" BorderThickness="1"
                                                Foreground="#5F2C4C" Click="CategoryButton_Click"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </WrapPanel>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <!-- Сетка товаров - ИЗМЕНЕНО на ListBox -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" 
                          HorizontalScrollBarVisibility="Disabled" Margin="0,0,0,20">
                <ListBox x:Name="ProductsListBox" 
                         SelectionMode="Single"
                         Background="Transparent"
                         BorderThickness="0">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel HorizontalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource ProductCardStyle}" Width="260">
                                <StackPanel>
                                    <!-- Изображение товара -->
                                    <Border Height="220" Background="#F5F5F5" CornerRadius="12,12,0,0">
                                        <Image Source="{Binding ImageUrl, Converter={StaticResource ImageConverter}}" 
                                               Stretch="Uniform" Margin="10"/>
                                    </Border>

                                    <StackPanel Margin="15">
                                        <!-- Название -->
                                        <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" 
                                                   Foreground="#5F2C4C" TextWrapping="Wrap" 
                                                   MaxHeight="50" Margin="0,0,0,8"/>

                                        <!-- Рейтинг -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <TextBlock Text="★" Foreground="#FFB800" FontSize="14"/>
                                            <TextBlock Text="4.85" Foreground="#666666" FontSize="13" Margin="5,0,0,0"/>
                                            <TextBlock Text="тыс." Foreground="#999999" FontSize="11" Margin="2,0,0,0"/>
                                        </StackPanel>

                                        <!-- Цена -->
                                        <TextBlock Text="{Binding Price, StringFormat={}{0:N0} ₽}" 
                                                   FontSize="22" FontWeight="Bold" 
                                                   Foreground="#7A3E65" Margin="0,0,0,5"/>

                                        <!-- Платежи -->
                                        <TextBlock Text="{Binding InstallmentText}" 
                                                   Foreground="#999999" FontSize="11"/>

                                        <!-- Статус наличия -->
                                        <Border Background="{Binding IsAvailable, Converter={StaticResource AvailabilityColorConverter}}" 
                                                CornerRadius="4" Padding="8,4" Margin="0,10,0,0" 
                                                HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding IsAvailable, Converter={StaticResource AvailabilityTextConverter}}" 
                                                       FontSize="10" Foreground="White"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>

            <!-- Кнопки действий -->
            <Border Grid.Row="3" Background="White" CornerRadius="12" 
                    Padding="15" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="BtnAdd" Content="➕ Добавить" 
                            Background="#7A3E65" Foreground="White"
                            Height="40" Width="120" Margin="8"
                            Click="BtnAdd_Click"/>
                    <Button x:Name="BtnEdit" Content="✏️ Редактировать" 
                            Background="#7A3E65" Foreground="White"
                            Height="40" Width="120" Margin="8"
                            Click="BtnEdit_Click"/>
                    <Button x:Name="BtnDelete" Content="🗑 Удалить" 
                            Background="#7A3E65" Foreground="White"
                            Height="40" Width="120" Margin="8"
                            Click="BtnDelete_Click"/>
                    <Button x:Name="BtnBack" Content="⬅ Назад" 
                            Background="Transparent" BorderBrush="#7A3E65" BorderThickness="1"
                            Foreground="#5F2C4C" Height="40" Width="100" Margin="8"
                            Click="BtnBack_Click"/>
                </StackPanel>
            </Border>

            <!-- Популярные категории -->
            <Border Grid.Row="4" Background="White" CornerRadius="12" Padding="20">
                <StackPanel>
                    <TextBlock Text="Вместе с товарами часто ищут" FontSize="16" FontWeight="SemiBold" 
                               Foreground="#5F2C4C" Margin="0,0,0,15"/>

                    <WrapPanel>
                        <Button Content="🌹 Розы" Width="100" Margin="5" Padding="8,5"
                                Background="Transparent" BorderBrush="#7A3E65" BorderThickness="1"
                                Foreground="#5F2C4C"/>
                        <Button Content="🌷 Тюльпаны" Width="100" Margin="5" Padding="8,5"
                                Background="Transparent" BorderBrush="#7A3E65" BorderThickness="1"
                                Foreground="#5F2C4C"/>
                        <Button Content="🌸 Пионы" Width="100" Margin="5" Padding="8,5"
                                Background="Transparent" BorderBrush="#7A3E65" BorderThickness="1"
                                Foreground="#5F2C4C"/>
                        <Button Content="🌿 Букеты" Width="100" Margin="5" Padding="8,5"
                                Background="Transparent" BorderBrush="#7A3E65" BorderThickness="1"
                                Foreground="#5F2C4C"/>
                        <Button Content="💐 Орхидеи" Width="100" Margin="5" Padding="8,5"
                                Background="Transparent" BorderBrush="#7A3E65" BorderThickness="1"
                                Foreground="#5F2C4C"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>