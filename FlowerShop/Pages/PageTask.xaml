<Page x:Class="FlowerShop.Pages.PageTask"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="PageTask">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource AccentBrush}" Padding="12" CornerRadius="10" Margin="0,0,0,12">
            <TextBlock Text="🌼 Каталог цветов и букетов"
                       FontSize="20"
                       FontWeight="Bold"/>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox x:Name="TbSearch" Width="220" Margin="0,0,10,0" TextChanged="TbSearch_TextChanged"/>
            <ComboBox x:Name="CbCategory" Width="180" Margin="0,0,10,0" SelectionChanged="CbCategory_SelectionChanged"/>
            <ComboBox x:Name="CbSort" Width="180" Margin="0,0,10,0" SelectionChanged="CbSort_SelectionChanged">
                <ComboBoxItem Content="Без сортировки" Tag="none" IsSelected="True"/>
                <ComboBoxItem Content="Цена по возрастанию" Tag="price_asc"/>
                <ComboBoxItem Content="Цена по убыванию" Tag="price_desc"/>
                <ComboBoxItem Content="Сначала новые" Tag="new"/>
            </ComboBox>
            <Button Content="Список" Width="90" Margin="0,0,8,0" Click="BtnListView_Click"/>
            <Button Content="Плитка" Width="90" Margin="0,0,8,0" Click="BtnTileView_Click"/>
            <Button Content="Добавить товар" Width="130" Click="BtnAdd_Click"/>
        </StackPanel>

        <Grid Grid.Row="2">
            <ListView x:Name="LvProducts" MouseDoubleClick="LvProducts_MouseDoubleClick">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Название" DisplayMemberBinding="{Binding name}" Width="200"/>
                        <GridViewColumn Header="Категория" DisplayMemberBinding="{Binding categories.name}" Width="160"/>
                        <GridViewColumn Header="Цена" DisplayMemberBinding="{Binding price}" Width="100"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <ScrollViewer x:Name="SvTiles" Visibility="Collapsed">
                <ItemsControl x:Name="IcProducts">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderThickness="1" BorderBrush="{StaticResource AccentBrush}" Background="{StaticResource SurfaceBrush}" Margin="6" Padding="8">
                                <StackPanel Width="180">
                                    <Image Height="100" Stretch="UniformToFill" Loaded="Image_Loaded" Tag="{Binding image_url}"/>
                                    <TextBlock Text="{Binding name}" FontWeight="Bold" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding categories.name}"/>
                                    <TextBlock Text="{Binding price}"/>
                                    <Button Content="В избранное" Click="BtnFavorite_Click" Tag="{Binding id}" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <TextBlock Grid.Row="3" x:Name="TbCounter" FontWeight="Bold" Margin="0,10,0,0"/>
    </Grid>
</Page>
