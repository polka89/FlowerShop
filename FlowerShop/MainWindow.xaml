<Window x:Class="FlowerShop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Flower Shop — Цветочный магазин" Height="720" Width="1200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource AccentBrush}" Padding="14">
            <TextBlock Text="🌸 Flower Shop"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryDarkBrush}"/>
        </Border>

        <Frame Grid.Row="1" x:Name="frmMain" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>
